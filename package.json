{
	"name": "resume-theme",
	"private": true,
	"scripts": {
		"build": "esbuild theme/build-entry.js --outfile=theme/dist/index.js --bundle --platform=node --format=cjs",
		"format": "prettier --write \"**/*.{js,jsx,json,md}\" --ignore-path .gitignore",
		"format:check": "prettier --check \"**/*.{js,jsx,json,md}\" --ignore-path .gitignore",
		"test": "node --test theme/**/__tests__/*.test.js"
	},
	"dependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"styled-components": "^6.1.19"
	},
	"devDependencies": {
		"esbuild": "^0.28.0",
		"fallow": "^2.73.0",
		"prettier": "^3.8.3",
		"resume-cli": "^3.1.2"
	}
}
